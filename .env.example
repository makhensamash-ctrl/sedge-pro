# ─────────────────────────────────────────────────────────────────────────────
# SEDGE Pro — Environment Variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) — exposed to the browser, OK to be public ────────────────
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...your-anon-key..."
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ── Supabase server-side (Edge Functions) ────────────────────────────────────
# Auto-injected by Supabase Cloud; required when self-hosting / running locally.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOi...your-anon-key..."
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...your-anon-key..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service-role..."   # SECRET — server only
SUPABASE_DB_URL="postgres://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# ── Resend (transactional email) ─────────────────────────────────────────────
# Get from https://resend.com → API Keys → Create
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ── Yoco (payment gateway) ───────────────────────────────────────────────────
# Get from https://portal.yoco.com → Developer → API Keys
Yoco_Secret="sk_live_or_test_xxxxxxxxxxxx"

# ── Admin bootstrap ──────────────────────────────────────────────────────────
# Temporary password assigned to newly invited admins (must be changed on first login)
DEFAULT_ADMIN_PASSWORD="ChangeMe!Strong#Password123"

# ── Optional: Lovable AI Gateway (only if you keep AI features routed via Lovable) ─
# Remove if migrating off Lovable entirely and replace with your own provider key.
# LOVABLE_API_KEY=""
